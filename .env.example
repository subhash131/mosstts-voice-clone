# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env for local development
# Cloud providers (Render, Railway) inject these automatically at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────

# Port the app listens on.
# • Render / Railway inject $PORT automatically — do NOT set this manually there.
# • For local Docker: leave unset to use the default (18083), or override here.
PORT=18083

# ── VSCode / Dev-Proxy (optional) ─────────────────────────────────────────────

# Set this when running inside a VSCode port-forwarding proxy (e.g. GitHub Codespaces).
# Format: the proxy URI template, e.g. https://your-codespace-{{port}}.preview.app.github.dev
# Leave blank for normal local or cloud deployments.
VSCODE_PROXY_URI=

# ── Fine-tuning / Distributed Training (optional) ────────────────────────────

# Total number of processes in a distributed training job.
# Only relevant when running finetuning/common.py in a multi-GPU/multi-node setup.
WORLD_SIZE=1

# Rank of this process in the distributed training job (0-indexed).
RANK=0
